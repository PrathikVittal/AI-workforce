# LLM provider: "ollama" (local, free, default) or "openai" (cloud, quality)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# To use the cloud API instead, set LLM_PROVIDER=openai and provide:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Infra
NATS_URL=nats://localhost:4222
DATABASE_URL=postgresql://USER@localhost:5432/scrum
EMBED_MODEL=nomic-embed-text
